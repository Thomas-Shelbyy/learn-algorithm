# hafiz-sakib er GitHub Personal Access Token (repo scope thakte hobe)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Thomas-shelby account er username (repo malik)
REPO_OWNER=thomas-shelby

# Repo naam jekhane PR jabe
REPO_NAME=your-repo-name

# Branch naam (default: sakib)
BRANCH_NAME=sakib

# Koto ta commit banabe (protita PR e)
COMMIT_COUNT=10

# Ek run e koto ta branch/PR banabe
PR_COUNT=5

# Local clone path
LOCAL_REPO_PATH=./repo

# Kon file e likha hobe
FILE_NAME=log.txt
